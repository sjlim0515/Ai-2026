   "source": [
    "n=int(input('수를 입력하세요: ' ))\n",
    "fact = 1 # 1을 넣어야 결과가 0이 나오지 않음 (곱셈이기때문)\n",
    "for i in range(1,n+1):\n",
    "    fact = fact * i\n",
    "\n",
    "print('{}! = {}'.format(n,fact))"
   ]
